{
	"name": "codex",
	"private": true,
	"version": "3.4.0",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"worker": "node --import ./src/worker/register.js src/worker/index.ts",
		"migrate": "node scripts/migrate.ts",
		"seed:admin": "node scripts/seed-admin.ts",
		"backup": "node scripts/run-backup.ts",
		"restore:backup": "node scripts/restore-backup.ts",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --fail-on-warnings",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:unit": "vitest",
		"test:e2e": "playwright test",
		"lint": "prettier --check . && eslint . --max-warnings 0",
		"format": "prettier --write ."
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^10.0.1",
		"@fontsource-variable/hanken-grotesk": "^5.2.8",
		"@fontsource-variable/jetbrains-mono": "^5.2.8",
		"@fontsource/spectral": "^5.2.8",
		"@playwright/test": "^1.60.0",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/d3-force": "^3.0.10",
		"@types/markdown-it": "^14.1.2",
		"@types/node": "^25",
		"@types/nodemailer": "^8.0.0",
		"@types/pg": "^8.20.0",
		"@types/qrcode": "^1.5.6",
		"drizzle-kit": "^0.31.10",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^4.1.0",
		"svelte": "^5.55.2",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^8.0.7",
		"vitest": "^4.1.8"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1061.0",
		"@aws-sdk/lib-storage": "^3.1061.0",
		"@codemirror/lang-markdown": "^6.5.0",
		"@codemirror/search": "^6.7.0",
		"@node-rs/argon2": "^2.0.2",
		"@simplewebauthn/browser": "^13.3.0",
		"@simplewebauthn/server": "^13.3.1",
		"codemirror": "^6.0.2",
		"d3-force": "^3.0.0",
		"diff": "^9.0.0",
		"drizzle-orm": "^0.45.2",
		"fflate": "^0.8.3",
		"markdown-it": "^14.2.0",
		"nodemailer": "^8.0.10",
		"pg": "^8.21.0",
		"pg-boss": "^12.18.2",
		"puppeteer-core": "^25.1.0",
		"qrcode": "^1.5.4"
	}
}
