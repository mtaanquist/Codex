# Copy to .env and adjust as needed. Two things read this file: the dev
# tooling (Vite, Vitest, drizzle-kit) and docker compose, which uses it
# for variable substitution in compose.yaml.

# --- Development (compose.dev.yaml) ---

# The defaults match the dev database container.
DATABASE_URL=postgres://codex:codex@localhost:5432/codex

# Integration tests use a separate throwaway database on the same server.
# They create it themselves if it does not exist.
TEST_DATABASE_URL=postgres://codex:codex@localhost:5432/codex_test

# Host port the dev database publishes. Change it if 5432 is taken, and
# update the two URLs above to match.
# DEV_DB_PORT=5432

# --- Deployment (compose.yaml) ---

# Database password for the stack. Set something strong for a real
# deployment; the app and worker pick it up automatically.
# POSTGRES_PASSWORD=codex

# Host port the app publishes. Point your reverse proxy here.
# APP_PORT=3000

# The public URL the app is reached on. Form submissions are rejected
# when this does not match what the browser sees, so set it to your real
# address, including the scheme and any non-standard port.
# ORIGIN=http://localhost:3000

# The stack runs without Caddy by default, expecting a reverse proxy of
# your own in front. Uncomment to run the bundled Caddy for TLS instead.
# COMPOSE_PROFILES=caddy

# With Caddy enabled: the address it serves. A bare domain makes Caddy
# obtain TLS certificates for it; ":80" serves plain HTTP on localhost.
# Remember to set ORIGIN to match (https://your.domain).
# SITE_ADDRESS=your.domain

# With Caddy enabled: the host ports it publishes.
# HTTP_PORT=80
# HTTPS_PORT=443

# --- Assets (uploaded images) ---

# Images upload to an S3-compatible bucket, separate from the backups
# bucket, and are served back through the app. Off until the bucket and
# both keys are set. Use a different bucket or prefix than the backups.
# For a local bucket, add "minio" to COMPOSE_PROFILES and point these at
# http://minio:9000 with the MinIO credentials below; note that keeps the
# images on this host, so for real disaster recovery use an external
# bucket (S3, B2, R2) here.
# ASSET_S3_ENDPOINT=https://s3.us-west-004.backblazeb2.com
# ASSET_S3_REGION=us-west-004
# ASSET_S3_BUCKET=my-codex-assets
# ASSET_S3_PREFIX=codex-assets
# ASSET_S3_ACCESS_KEY_ID=...
# ASSET_S3_SECRET_ACCESS_KEY=...

# Credentials for the bundled MinIO (COMPOSE_PROFILES=minio); it creates
# the codex-assets and codex-backups buckets on first start.
# MINIO_ROOT_USER=codex-minio
# MINIO_ROOT_PASSWORD=codex-minio-secret

# Upload size cap passed to the Node adapter; image uploads allow 10 MB.
# BODY_SIZE_LIMIT=15M

# --- Off-site backups ---

# Hourly database dumps to any S3-compatible bucket (S3, Backblaze B2,
# MinIO, R2). Off until the bucket and both keys are set. When nothing
# changed since the last dump, the upload is skipped. The admin's library
# page shows recent runs and a "Back up now" button.
# Restore with: node scripts/restore-backup.ts latest
# BACKUP_S3_ENDPOINT=https://s3.us-west-004.backblazeb2.com
# BACKUP_S3_REGION=us-west-004
# BACKUP_S3_BUCKET=my-codex-backups
# BACKUP_S3_ACCESS_KEY_ID=...
# BACKUP_S3_SECRET_ACCESS_KEY=...

# Key prefix inside the bucket and the schedule (cron, UTC).
# BACKUP_S3_PREFIX=codex-backups
# BACKUP_CRON=0 * * * *

# Tiered retention: keep every dump from the last N hours, then the
# newest per day going back N days. Older dumps are pruned.
# BACKUP_KEEP_RECENT_HOURS=48
# BACKUP_KEEP_DAYS=30

# --- Secrets ---

# Key used to encrypt secrets stored in the database (the SMTP password set
# from the admin panel, two-factor authenticator secrets, and later LLM keys),
# and to sign the two-factor and passkey sign-in challenges. Set a long random
# value for a real deployment and keep it stable; changing it makes stored
# secrets unreadable and breaks two-factor sign-in until it is set up again.
# Without it, the admin panel cannot store an SMTP password (though SMTP can
# still be seeded from the variables below), and two-factor authentication and
# passkeys are unavailable.
# APP_SECRET=change-me-to-a-long-random-string

# --- Email (SMTP relay) ---

# Sends verification, password-reset, and admin-notification emails. These
# seed the relay; the site admin panel can override them and store the
# password encrypted. With nothing set, emails are written to the worker log
# instead of sent.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apikey
# SMTP_PASSWORD=...
# SMTP_FROM=Codex <no-reply@example.com>
