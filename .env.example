# Copy to .env and adjust as needed. Two things read this file: the dev
# tooling (Vite, Vitest, drizzle-kit) and docker compose, which uses it
# for variable substitution in compose.yaml.

# --- Development (compose.dev.yaml) ---

# The defaults match the dev database container.
DATABASE_URL=postgres://codex:codex@localhost:5432/codex

# Integration tests use a separate throwaway database on the same server.
# They create it themselves if it does not exist.
TEST_DATABASE_URL=postgres://codex:codex@localhost:5432/codex_test

# Host port the dev database publishes. Change it if 5432 is taken, and
# update the two URLs above to match.
# DEV_DB_PORT=5432

# --- Deployment (compose.yaml) ---

# Database password for the stack. Set something strong for a real
# deployment; the app and worker pick it up automatically.
# POSTGRES_PASSWORD=codex

# Host port the app publishes. Point your reverse proxy here.
# APP_PORT=3000

# The public URL the app is reached on. Form submissions are rejected
# when this does not match what the browser sees, so set it to your real
# address, including the scheme and any non-standard port.
# ORIGIN=http://localhost:3000

# The stack runs without Caddy by default, expecting a reverse proxy of
# your own in front. Uncomment to run the bundled Caddy for TLS instead.
# COMPOSE_PROFILES=caddy

# With Caddy enabled: the address it serves. A bare domain makes Caddy
# obtain TLS certificates for it; ":80" serves plain HTTP on localhost.
# Remember to set ORIGIN to match (https://your.domain).
# SITE_ADDRESS=your.domain

# With Caddy enabled: the host ports it publishes.
# HTTP_PORT=80
# HTTPS_PORT=443
