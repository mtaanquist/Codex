{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm install)",
      "Bash(npm ci)",
      "Bash(npm run *)",
      "Bash(npx *)",
      "Bash(pnpm *)",
      "Bash(node *)",
      "Bash(docker *)",
      "Bash(service docker start)",
      "Bash(playwright *)",
      "Bash(drizzle-kit *)",
      "Bash(git *)",
      "Bash(psql *)",
      "Bash(pg_isready *)",
      "Bash(pg_dump *)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.local)",
      "Read(.env.*.local)"
    ]
  },
  "env": {
    "NODE_ENV": "development",
    "DATABASE_URL": "postgres://codex:codex@localhost:5432/codex"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/session-setup.sh\""
          }
        ]
      }
    ]
  }
}
